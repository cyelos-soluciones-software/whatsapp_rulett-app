# PostgreSQL — misma BD que rulett.app (Neon en prod, local en dev)
# En Neon usa la URL externa (no localhost). Quita ?schema=public si la copiaste de Prisma.
DATABASE_URL=postgresql://rulett_admin:rulett_secure_password_local@localhost:5440/rulett_db

# Polling
POLL_INTERVAL_MS=60000
BATCH_SIZE=50

# Meta WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=1064133880126015
WHATSAPP_ACCOUNT_ID=868325479011642
WHATSAPP_LANGUAGE_CODE=es_CO

# Local: false | Neon/Render: true (si usas neon.tech se infiere solo)
DATABASE_SSL=false

# Opcional: forzar IDs en el seed (si no, se resuelven desde la BD)
# SEED_TENANT_ID=
# SEED_QR_CAMPAIGN_ID=
